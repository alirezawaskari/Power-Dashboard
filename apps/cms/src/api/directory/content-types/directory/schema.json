{
  "kind": "collectionType",
  "collectionName": "directories",
  "info": {
    "singularName": "directory",
    "pluralName": "directories",
    "displayName": "Directory"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Path": {
      "type": "string",
      "required": true
    },
    "Children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::directory.directory",
      "mappedBy": "Parent"
    },
    "Parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::directory.directory",
      "inversedBy": "Children"
    },
    "Files": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::file-record.file-record",
      "mappedBy": "Folder"
    }
  }
}
